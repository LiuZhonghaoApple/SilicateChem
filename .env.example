# Site
NEXT_PUBLIC_SITE_URL=https://silicatechem.com

# Analytics — GA4 property for silicatechem.com (production measurement ID)
NEXT_PUBLIC_GA4_ID=G-R7W0MMX4SW
# Optional — only if using GTM; GA4-direct via NEXT_PUBLIC_GA4_ID is primary
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Email delivery — Resend (recommended for Vercel)
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
INQUIRY_TO_EMAIL=padelonesource@gmail.com
INQUIRY_FROM_EMAIL=info@silicatechem.com

# Cloudflare Turnstile — spam protection on inquiry forms
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxx

# SMTP alternative (uncomment if using Nodemailer instead of Resend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Rate limiting — Upstash Redis (works with Vercel KV)
# https://upstash.com/docs/redis/overall/getstarted
# Vercel KV uses KV_REST_API_URL / KV_REST_API_TOKEN (aliases below also supported)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
