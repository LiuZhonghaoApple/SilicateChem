# Site
NEXT_PUBLIC_SITE_URL=https://silicatechem.com

# Analytics — GA4 property for silicatechem.com (production measurement ID)
NEXT_PUBLIC_GA4_ID=G-R7W0MMX4SW
# Optional — only if using GTM; GA4-direct via NEXT_PUBLIC_GA4_ID is primary
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Daily read-only GA4 and Search Console reporting sync
GA4_PROPERTY_ID=542189602
GSC_SITE_URL=https://www.silicatechem.com/
# Recommended on Vercel: store the complete service-account key as one Sensitive value.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Optional split-value alternative to GOOGLE_SERVICE_ACCOUNT_JSON
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Email delivery — Resend (recommended for Vercel)
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
INQUIRY_TO_EMAIL=padelonesource@gmail.com
INQUIRY_FROM_EMAIL=info@silicatechem.com

# CRM database and administrator login
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
ADMIN_USERNAME=admin
# Format: pbkdf2-sha256$iterations$salt$hash
ADMIN_PASSWORD_HASH=pbkdf2-sha256$210000$replace-with-salt$replace-with-hash
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes
# Optional: separate salt used to irreversibly hash visitor IP addresses
ATTRIBUTION_HASH_SECRET=replace-with-at-least-32-random-bytes
# Optional: separate HMAC secret for persistent rate-limit identifiers.
# Falls back to ATTRIBUTION_HASH_SECRET, then ADMIN_SESSION_SECRET.
RATE_LIMIT_HASH_SECRET=replace-with-at-least-32-random-bytes
# Protects Vercel Cron requests to the IndexNow submission endpoint
CRON_SECRET=replace-with-at-least-32-random-bytes

# Low-cost AI Procurement Advisor controls
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx
AI_ADVISOR_MODEL=gpt-5-nano
AI_ADVISOR_MAX_OUTPUT_TOKENS=450
AI_ADVISOR_HOURLY_LIMIT=10
AI_ADVISOR_DAILY_LIMIT=100

# Cloudflare Turnstile — spam protection on inquiry forms
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxx

# SMTP alternative (uncomment if using Nodemailer instead of Resend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Rate limiting is persisted in the existing Neon/Postgres database.
